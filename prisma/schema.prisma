generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id            String    @id @default(cuid())
  sid           String    @unique @default(cuid())
  name          String
  email         String    @unique
  phone         String    @default("")
  location      String
  source        String    @default("website")
  status        String    @default("lead")
  statusReason  String?
  notes         String?
  appointmentAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  intakes Intake[]

  @@index([email])
  @@index([location])
  @@index([status])
  @@index([appointmentAt])
}

model WebhookLog {
  id         String   @id @default(cuid())
  endpoint   String
  status     Int
  error      String?
  payload    String
  createdAt  DateTime @default(now())

  @@index([endpoint])
  @@index([createdAt])
}

model Intake {
  id                  String   @id @default(cuid())
  leadId              String
  lead                Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  coach               String?
  dob                 String?
  emergencyName       String?
  emergencyPhone      String?
  goals               String?
  experience          String?
  injuries            String?
  howHeard            String?
  programInterest     String?
  availableClasses    String?
  waiverAccepted      Boolean  @default(false)
  createdAt           DateTime @default(now())

  @@index([leadId])
}

model CareerApplication {
  id              String            @id @default(cuid())
  roleSlug        String
  roleTitle       String
  fullName        String
  email           String
  phone           String?
  whyThisRole     String
  keyExperience   String
  twoYearVision   String
  resumeUrl       String?
  linkedinUrl     String?
  status          ApplicationStatus @default(NEW)
  notes           String?
  source          String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([roleSlug])
  @@index([status])
  @@index([createdAt])
  @@index([email])
}

enum ApplicationStatus {
  NEW
  REVIEWING
  PHONE_SCREEN
  IN_PERSON
  ROLE_PLAY
  TRIAL
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}
